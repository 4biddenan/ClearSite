sinessNameComposer:"Business Name Creator",businessIdeaComposer:"Business Idea Creator",googleAdCreator:"Google Ad Creator",websiteBuilderGPT:"Create a site from ChatGPT"},createFromLink:{title:"Create a website",[a.CreateFromLink.Facebook]:{label:"Create a site from Facebook",href:"/create-your-website-with-facebook"},[a.CreateFromLink.Generic]:{label:"Create a site from a link",href:"/create-a-website-from-a-link"},[a.CreateFromLink.GitHub]:{label:"Create a site from GitHub",href:"/github-to-website"},[a.CreateFromLink.Thumbtack]:{label:"Create a site from Thumbtack",href:"/create-your-website-with-thumbtack"},[a.CreateFromLink.Yelp]:{label:"Create a site from Yelp",href:"/create-your-website-with-yelp"}},company:{title:"Company",about:"About us",pricing:"Pricing",blog:"Blog",demoVideo:"Video Demo",support:"Support",releaseNotes:"Release notes",featuredIndustries:"Featured Businesses",integrations:"Integrations",affiliate:"Affiliate Program"}},secondaryTextArea:{privacyPolicy:"Privacy Policy",terms:"Terms of Service"}},heroArea:{title:"Launch your business with a free website",titleBreak:"Launch your business\nwith a free website",description:"Connect your custom domain for free. Let us grow your business.",customDomain:"Connect your custom domain for free!",button:"Create Your Website",buttonLabel:"Solo AI Onboarding Page (opens in a new tab)",jobs:["coaching","dog walking","therapy","tutoring","hair styling","landscaping","nutritionist","car detailing","carpentry","training","pest control","consulting","copywriting","plumbing","mural art"]},heroBanner:{titleA:"Create a beautiful website",titleB:"with a few simple inputs"},servicesArea:{noCodeRequired:{title:"No code required",description:"Solo creates your website from a few simple inputs--organizing sections, and curating initial images with AI assistance"},brandVisibility:{title:"Improve brand visibility",description:"SEO keywords are automatically added to help drive search traffic. View statistics by connecting a Google Analytics account"},importReviews:{title:"Import reviews",description:"Solo can sample text and reviews from your existing social and showcase the best content"},easyBooking:{title:"Make booking easier",description:"Link your supported calendar to allow booking of services from your website"},mobileSite:{title:"A mobile site too",description:"Your website is designed to look great on different devices with no extra hassle"},clientContact:{title:"Client contact form",description:"Receive messages from customers directly to your inbox so you can easily follow up"},customDomain:{title:"Connect your custom domain for free. Let us grow your business.",description:"Connect and host a custom domain for free, or shop for a domain at a discount"},siteAnalytics:{title:"View site analytics",description:"Configure your Google Analytics account to view referers, pageviews and more"},inviteEditors:{title:"Invite website editors",description:"Invite others to collaborate on design, and create content for your website"}},superchargeBanner:{title:"Focus on what you do best",description:{partA:"An optimized website can help ",partB:"grow your business",partC:" while you focus on everything else"},cards:{petCare:"Pet Care",tutoring:"Tutoring",construction:"Construction",coaching:"Coaching",consulting:"Consulting",therapy:"Therapy",styling:"Styling",nutrition:"Nutrition"}},samplesBanner:{title:"Style to suit your business",description:"Simple tools let you quickly arrange and re-style your site"},testimonialsArea:{title:"Testimonials",subtitle:"See more Solo reviews on ",google:"Google",trustpilot:"Trustpilot",and:"and",testimonials:[{author:"LegendRise Consulting",body:"I appreciate Soloist AI's user-friendly interface and efficient design tools, which streamlined the process of creating and editing my website. Its seamless functionality and customization options allowed me to build a professional site with minimal effort."},{author:"Elite Builders Group",body:"Everything was seamless and straight forward, and the pricing is great. I have always been slightly daunted by the subject of web design, so the templates and prompts made life much easier for me."},{author:"Elgin Design Services",body:"Solo is so easy to use. Got the site up and running in around 20 minutes. I've designed lots of sites in the past and this is by far the quickest and easiest site I've ever made. Highly recommended!"},{author:"Monique Toms",body:"It is the easiest app that I have found for setting up and hosting a website, I have many years of experience with computers and searching the web but minimal in programming"},{author:"Bom Dia Network",body:"Has an inviting simplicity to create a website. You can't do anything wrong, everything happens so quickly that you just focus on the content."},{author:"Roger Holloway",body:"I was surprised how easy and intuitive the interface was, and had a bunch of fun creating my first website for real estate here in the Charlotte market."},{author:"WAN5 Geological Surveying Services",body:"Solo AI is great! It makes my website so easy, fast, simple, and less worrisome. My friends told me it was awesome and I am happy and grateful about it."},{author:"Jump & Shout Wellness Studios",body:"Solo is easy to use and comes with resources that provide answers to many questions. The staff is stellar and quick to respond to questions and inquiries. A great value that stands tall against competitors."}]},faqArea:{title:"Frequently asked questions",subtitle:"You can learn more in",soloSupport:"Solo Support",description:"Text here for SEO optimization",items:[{question:"What does Solo cost?",answer:"Solo AI website creator allows you to connect and host your custom domain for free. We are not going to put ads on your website. We also offer a <a href='https://soloist.ai/pricing'>Pro plan</a> for more features and websites including a lifetime domain."},{question:"Can I connect a custom domain to my Solo website?",answer:"After you set up your Solo website, you can connect a custom domain that is personalized to your business. Websites with custom domains see more traffic and as a result more business!"},{question:"Can I connect my scheduling service to my Solo site?",answer:"Yes, in the Scheduling section for your website, provide a link to your scheduling service whether Calendly, Tidycal or other."},{question:"Can I link to my existing social media pages?",answer:"Yes, you can provide links to all of your social accounts and display them in the Header and Footer of your website."},{question:"Can I sell products on my website?",answer:"Yes. You can use the Services section type to add your products with pricing and then attach payment links from Stripe or Paypal so your users can complete the purchase."},{question:"Can I invite editors to my website?",answer:"Yes. You can use the Invite Editor feature available from the Share button in the top toolbar and invite a user to edit the website."},{question:"How can I add a chatbot to my website?",answer:"You can use the Custom Code option available in Settings to insert the chatbot code based on the chatbot provider you have chosen."},{question:"Is my website mobile-friendly?",answer:"Yes. Solo AI Website Creator optimizes your website for desktop and mobile from the start so it looks great on any device, with no extra work required from you."},{question:"How can I edit or update the content on my Solo website?",answer:"You can visit <a href='https://soloist.ai/designer'>https://soloist.ai/designer</a>, login to your account using the method you used to sign up (Google or Email), and start making the changes as needed."}]},callToActionArea:{title:"Ready to start creating?",description:"Get your free website in just minutes after answering a few short questions",button:"Create Your Website",buttonLabel:"Solo AI Onboarding Page (opens in a new tab)"},growCallToActionArea:{title:"Let us grow your business",description:"Schedule a kick-off call for assistance with your blog & social media posts",button:"Create Your Website",buttonLabel:"Solo AI Onboarding Page (opens in a new tab)"},title:"Solo - Free AI Website Creator",siteName:"Solo - Free AI Website Creator",siteDescription:"Create a beautiful website for your business from a few simple inputs"},pricing:{title:"Pricing",tiersArea:{title:"Pricing",description:"Launch your business with a free website and a lifetime free custom domain while subscribed.",perMonth:"/month",freeTier:{tier:"Free",pricing:"$0",button:"Create a Website",description:"No credit card required to begin",featuresHeading:"Basics to get started",features:{customDomains:"Connect + host your own domain",publishedWebsites:"{count|published site}",editors:"Invite {count|additional site editor}"}},proTier:{tier:"Pro",pricing:{monthly:"$".concat((0,l.q)(a.PlanType.PRO,a.BillingCycle.MONTHLY).price),yearly:"$".concat((0,l.q)(a.PlanType.PRO,a.BillingCycle.YEARLY).price)},description:(0,r.jsxs)(r.Fragment,{children:[(0,r.jsxs)("b",{children:["Save $",(0,l.d)(a.PlanType.PRO),"/year"]})," ","with annual billing"]}),button:"Get Started",startingAt:"Starting at",featuresHeading:"More freedom to build",features:{freeDomain:"Free lifetime domain included. Never pay for renewals.",customDomains:"Connect + host 5 custom domains",customCode:"Add custom code",duplicate:"Duplicate sites, sections, and pages",uploadedImages:"Upload more images",pexelsStockPhotos:"High-quality Pexels stock images"}},growTier:{tier:"Grow",pricing:{monthly:"$".concat((0,l.q)(a.PlanType.GROW,a.BillingCycle.MONTHLY).price),yearly:"$".concat((0,l.q)(a.PlanType.GROW,a.BillingCycle.YEARLY).price)},description:(0,r.jsxs)(r.Fragment,{children:[(0,r.jsxs)("b",{children:["Save $",(0,l.d)(a.PlanType.GROW),"/year"]})," ","with annual billing"]}),button:"Get Started",upgradeButton:"Upgrade",startingAt:"Starting at",featuresHeading:"Let us grow your business",features:{proIncluded:"Everything in Pro, plus:",kickoff:"A kickoff call to discuss your brand and strategy",contentManagement:"Personalized management of your blog and social media posts. Prepared and scheduled for your review.",restrictions:"Restrictions apply*"}},legalText:"*Not available for legal or other services prohibited under the",legalLinkText:"Mozilla Acceptable Use Policy"},toutsArea:{title:"All plans include",touts:{[u.N.WebsiteAnalytics]:{title:"Website Analytics",description:"Connect to Google Analytics to manage your website performance."},[u.N.DomainHosting]:{title:"Domain hosting is Included",description:"All plans include connecting and hosting your custom domain. Discount domains are available."},[u.N.SEOOptimization]:{title:"SEO Optimization",description:"SEO keywords are automatically added to help drive search traffic."},[u.N.CodeEmbed]:{title:"Code Embed Sections",description:"Paste code from other web services to extend your website's functionality."},[u.N.NewsletterAndContactForm]:{title:"Newsletter and Contact Forms",description:"Collect addresses for a newsletter, or contact through a customizable form."},[u.N.ExportContacts]:{title:"Export Contacts",description:"Download a spreadsheet of website submissions (CSV file)."},[u.N.StockImagesLibrary]:{title:"Stock Images Library",description:"Customize your sites with access over 7 million high-quality stock images from Unsplash."},[u.N.SSLCertificate]:{title:"SSL Certificate",description:"Keep your website visitors safe with encrypted and secure connections."},[u.N.MobileOptimization]:{title:"Mobile Optimized Site",description:"Your website is designed to look great on different devices with no extra hassle."}}},faqArea:{title:"Frequently asked questions",items:[{question:"Do I need a credit card to use the Free plan?",answer:"No. You can create, design, and manage websites on the Free plan without a credit card. You'll only add a payment method if you upgrade to Pro or need to purchase a new domain."},{question:"Can I cancel or switch between monthly and annual?",answer:"Yes. You can change billing periods or cancel anytime from Account Settings (click your profile icon → Billing). When you cancel, your plan stays active until the end of the current billing cycle."},{question:"Do I keep ownership of my free custom domain if I leave Solo?",answer:"Yes. If you redeemed the free domain through Solo Domains or our partner IONOS, the domain is registered to you. You manage DNS settings and domain billing directly in your Solo or IONOS account."},{question:"What payment methods do you support?",answer:"We accept major credit and debit cards including Apple and Google Pay. Solo Pro is available worldwide. You can download payment invoices by visiting Solo Account Settings. "},{question:"Can I invite editors to my website?",answer:"Yes, on the Pro plan you can invite up to 5 editors."},{question:"Can I export my website or migrate elsewhere?",answer:"You can always export your contact and newsletter form submissions. You can also log into Solo to copy text and images. Solo does not, however, currently offer a way to export your website to HTML."}]}},industry:{allIndustriesLandingPage:{featuredArea:{title:"Featured Businesses",description:"Designed with a focus on service businesses, get a website today",button:"Create Your Website",featuredIndustries:{[a.Industry.Fitness]:{description:"Convey your approach to training with a bio, photos and video. Link clients to a scheduling app."},[a.Industry.Carpentry]:{description:"Showcase examples of your work and describe your services in detail to convey the value of craftsmanship."},[a.Industry.RealEstateAgent]:{description:"Introduce yourself to potential customers with select reviews. Share links out to important resources."},[a.Industry.BarberShop]:{description:"Online presence for your shop with location and contact info. Link out to your preferred scheduling app."},[a.Industry.CoffeeShop]:{description:"An online home for your local neighborhood cafe. Show off your drinks and friendly atmosphere."},[a.Industry.BookStore]:{description:"Publish location and contact details. Show off your cozy space with a gallery and link to your online shop."}}},iconsArea:{title:"Solo powers 10,000s of small business websites"}},industriesPage:{headingDescription:"Create a beautiful website from a few simple inputs. Host your custom domain with us for free!",buildYourWebsite:"Create Your Website",description:"Create a beautiful website for your {business-type} business from a few simple inputs",industryCapsuleLabel:"Solo AI Onboarding Page for {industry-name} (opens in a new tab)",industries:{[a.Industry.Accountant]:{industry:"Accountant",introHeading:"Free AI Website Creator for Accountants",featuresHeading:"Website features to help you start and grow your Accounting business"},[a.Industry.BarberShop]:{industry:"Barber Shop",introHeading:"Free AI Website Creator for Barber Shops",featuresHeading:"Website features to help you start and grow your Barber Shop"},[a.Industry.BikeShop]:{industry:"Bike Shop",introHeading:"Free AI Website Creator for Bicycle Shops",featuresHeading:"Website features to help you start and grow your Bicycle Shop"},[a.Industry.BookStore]:{industry:"Book Store",introHeading:"Free AI Website Creator for Book Shops",featuresHeading:"Website features to help you start and grow your Book Shop"},[a.Industry.CarDetailing]:{industry:"Car Detailing",introHeading:"Free AI Website Creator for Car Detailers",featuresHeading:"Website features to help you start and grow your Car Detailing business"},[a.Industry.Carpentry]:{industry:"Carpentry",introHeading:"Free AI Website Creator for Carpentry Businesses",featuresHeading:"Website features to help you start and grow your Carpentry business"},[a.Industry.Catering]:{industry:"Catering",introHeading:"Free AI Website Creator for Catering Businesses",featuresHeading:"Website features to help you start and grow your Catering business"},[a.Industry.ChessInstructor]:{industry:"Chess Instructor",introHeading:"Free AI Website Creator for Chess Instructors",featuresHeading:"Website features to help you start and grow your Chess Instruction business"},[a.Industry.CoffeeShop]:{industry:"Coffee Shop",introHeading:"Free AI Website Creator for Coffee Shops",featuresHeading:"Website features to help you start and grow your Coffee Shop"},[a.Industry.CondoRentalAgency]:{industry:"Condo Rental Agency",introHeading:"Free AI Website Creator for Condo Rental Agencies",featuresHeading:"Website features to help you start and grow your Condo Rental Agency"},[a.Industry.DentistOffice]:{industry:"Dentist Office",introHeading:"Free AI Website Creator for Dentist Offices",featuresHeading:"Website features to help you start and grow your Denstist Office"},[a.Industry.Electrician]:{industry:"Electrician",introHeading:"Free AI Website Creator for Electricians",featuresHeading:"Website features to help you start and grow your Electrician business"},[a.Industry.Fitness]:{industry:"Fitness",introHeading:"Free AI Website Creator for Fitness Trainers",featuresHeading:"Website features to help you start and grow your Fitness business"},[a.Industry.HairStyling]:{industry:"Hair Stylist",introHeading:"Free AI Website Creator for Hair Stylists",featuresHeading:"Website features to help you start and grow your Hair Styling business"},[a.Industry.HeatingAndCooling]:{industry:"Heating & Cooling",introHeading:"Free AI Website Creator for Heating and Cooling Businesses",featuresHeading:"Website features to help you start and grow your Heating and Cooling business"},[a.Industry.HomeConstruction]:{industry:"Home Construction",introHeading:"Free AI Website Creator for Home Construction Businesses",featuresHeading:"Website features to help you start and grow your Home Construction business"},[a.Industry.HouseCleaning]:{industry:"House Cleaning",introHeading:"Free AI Website Creator for House Cleaning Businesses",featuresHeading:"Website features to help you start and grow your House Cleaning business"},[a.Industry.Landscaping]:{industry:"Landscaping",introHeading:"Free AI Website Creator for Landscaping Businesses",featuresHeading:"Website features to help you start and grow your Landscaping business"},[a.Industry.MedicalClinic]:{industry:"Medical Clinic",introHeading:"Free AI Website Creator for Medical Clinics",featuresHeading:"Website features to help you start and grow your Medical Clinic"},[a.Industry.MusicLessons]:{industry:"Music Lessons",introHeading:"Free AI Website Creator for Music Instructors",featuresHeading:"Website features to help you start and grow your Music Instruction business"},[a.Industry.NonProfitOrganization]:{industry:"Non Profit Organization",introHeading:"Free AI Website Creator for Non Profit Organizations",featuresHeading:"Website features to help you start and grow your Non Profit Organization"},[a.Industry.Nutritionist]:{industry:"Nutritionist",introHeading:"Free AI Website Creator for Nutritionists",featuresHeading:"Website features to help you start and grow your Nutritionist practice"},[a.Industry.PestControl]:{industry:"Pest Control",introHeading:"Free AI Website Creator for Pest Control Businesses",featuresHeading:"Website features to help you start and grow your Pest Control business"},[a.Industry.PhysicalTherapist]:{industry:"Physical Therapist",introHeading:"Free AI Website Creator for Physical Therapists",featuresHeading:"Website features to help you start and grow your Physical Therapy practice"},[a.Industry.RealEstateAgent]:{industry:"Real Estate Agents",introHeading:"Free AI Website Creator for Real Estate Agents",featuresHeading:"Website features to help you start and grow your Real Estate business"},[a.Industry.Restaurant]:{industry:"Restaurant",introHeading:"Free AI Website Creator for Restaurants",featuresHeading:"Website features to help you start and grow your Restaurant business"},[a.Industry.Spa]:{industry:"Spa",introHeading:"Free AI Website Creator for Spa Businesses",featuresHeading:"Website features to help you start and grow your Spa business"},[a.Industry.TechnologyConsulting]:{industry:"Technology Consulting",introHeading:"Free AI Website Creator for Technology Consultants",featuresHeading:"Website features to help you start and grow your Physical Therapy practice"},[a.Industry.Therapist]:{industry:"Therapist",introHeading:"Free AI Website Creator for Therapists",featuresHeading:"Website features to help you start and grow your Therapy practice"},[a.Industry.TireShop]:{industry:"Tire Shop",introHeading:"Free AI Website Creator for Tire Shops",featuresHeading:"Website features to help you start and grow your Physical Tire Shop business"}}}},about:{welcomeSection:{title:"Welcome to Solo",description:(0,r.jsxs)(r.Fragment,{children:["My journey with Solo AI Website Creator began during the pandemic. I wanted to teach kids how to play chess for free while also running my tech startup. Like other solopreneurs, freelancers and hobbyists, I dabbled with tools such as Wix and Squarespace but I struggled with the multitude of settings, design choices and simply drafting and curating the content and images.",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),"Fast forward to 2023, and upon joining Mozilla, there was an opportunity to build something better with generative AI and thus, Solo was born. In our short time operating Solo, we've seen thousands of happy businesses take advantage of our service to build and host their website, which is just awesome!",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),"What I really love is we are democratizing access to solopreneurs. We make website creation accessible, especially for the non-technical. We use AI to address major painpoints around writing and design. We then take it a step further and make it 100% free so you can put every dollar towards growing your business. ",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),"We hope Solo works for you and if you have any feedback, please contact us at"," ",(0,r.jsx)("a",{href:"mailto:support@soloist.ai",children:"support@soloist.ai"}),(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),"- Raj & Solo Team",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),"P.S. To read more about the work involved in building Solo,"," ",(0,r.jsx)("a",{href:"https://future.mozilla.org/news/insights-from-launching-mozillas-ai-website-creator-solo-and-how-its-shaking-up-the-21-billion-industry/",target:"_blank",rel:"noreferrer",children:"see this post on the Mozilla blog"}),"."]})},productOverview:{title:"How we're different from other website builders?",description:(0,r.jsxs)(r.Fragment,{children:["With Solo, you can instantly create a website for your business. In the coming months, we'll be adding more features to help grow your business. Solo is:",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),(0,r.jsx)("b",{children:"Simple:"})," We made Solo so you don't need to rely on your 'tech buddy.' We intentionally limited the design and editing choices so you're not overwhelemed by options and settings.",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),(0,r.jsx)("b",{children:"Beautiful:"})," Solo websites look great on the desktop and from your mobile phone. We even integrated light-weight animations so your business website looks as polished as your business itself!",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),(0,r.jsx)("b",{children:"Fast:"})," Solo's AI does the hard part and fast. It generates the content and curates the images. Too many solopreneurs have told us that they tried to build their website but got stuck here.",(0,r.jsx)("br",{}),(0,r.jsx)("br",{}),(0,r.jsx)("b",{children:"Free:"})," As far as we know, Solo is the only AI Website Creator where you can connect and host your custom domain for free. We want to democratize access for builders and this is the best way to do it."]})},testimonialsSection:{title:"Customer testimonials",testimonials:[{testimonial:"In a matter of a few minutes I was able to get a professional website!",name:"Dhruv"},{testimonial:"Solo is the greatest thing ever. I was able to launch a website within three hours, and with no trouble at all. Now I have the perfect, sleek, sophisticated website and you gave it to me in hours, for free.",name:"Richelle"},{testimonial:"I'm sharing Solo to all my clients who want to own their own ecosystem of online presence, some variation on your name that signals authority and recency, and a link to a social media that you're active on.",name:"Personal Security Village"}]},metricSection:{title:"Helping service businesses and solo entrepeneurs see big impact, in no time",source:"Source: ",metricCards:[{text:"of all web traffic comes from Google search. Having a website is key.",highlight:"91%",footnote:{number:1,text:"StatCounter, "}},{text:"believe a business with a website is more credible than one that with just a social media page.",highlight:"84%",footnote:{number:2,text:"Verisign, "}},{text:"Average growth by retailers using a website as a tool to connect with customers.",highlight:"15-50%",footnote:{number:3,text:"RainPOS"}}]}},login:{emailLinkExpiredView:{header:"Email link expired",description:"The email link you supplied has expired. Get a new link and sign in\n again to access your account.",button:"Request New Link"},deviceNotSupportedView:{header:"Device not supported",description:"This device does not support Magic Link sign in. Please open the\nmagic link with the device you entered your email with.",button:"Visit Solo Homepage"}},onboarding:{businessDetailsView:{businessName:"Business name",businessDetails:"Description",businessDetailsPlaceholder:"e.g. Dogwalking business specializing in small & older dogs. Pricing from $24 to $75 per hour. 3 years of experience.",title:"What's your website about?",businessLocation:"Business location",businessLocationStatusDetecting:"Finding location",businessLocationStatusDetected:"Location found",businessLinksDescription:"Provide a URL to a Yelp, Facebook or other page for your business",businessLinksDescriptionMobile:"A link your Facebook, Yelp, or other business profile",invalidUrlTooltip:"Please enter a valid web address",